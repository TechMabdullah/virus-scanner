# Get a free key at https://www.virustotal.com/gui/join-us
VT_API_KEY=your_virustotal_api_key_here

# Local MongoDB, or a free Atlas cluster connection string
MONGO_URI=mongodb://127.0.0.1:27017/virus-scanner

PORT=5000

# Any long random string — used to sign login tokens
JWT_SECRET=change_this_to_a_long_random_string

# Comma-separated list of origins allowed to call this API
CLIENT_ORIGIN=http://localhost:5173
